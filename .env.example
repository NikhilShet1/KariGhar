# Server Configuration
PORT=5000
NODE_ENV=development

# Supabase Credentials
# Find these in Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anonymous-public-api-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-api-key-for-admin-bypass

# Supabase PostgreSQL Connection (Direct DB access)
# Find in Supabase Dashboard -> Project Settings -> Database -> Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres

# Gemini API Key (for voice descriptions, translations, and low-literacy helpers)
GEMINI_API_KEY=your-gemini-api-key
